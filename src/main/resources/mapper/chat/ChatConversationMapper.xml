<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.chat.mapper.ChatConversationMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.demo.chat.entity.ChatConversationEntity">
        <id column="id" property="id"/>
        <result column="conversation_uuid" property="conversationUuid"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
        <result column="status" property="status"/>
        <result column="message_count" property="messageCount"/>
        <result column="last_message_at" property="lastMessageAt"/>
        <result column="metadata" property="metadata"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, conversation_uuid, user_id, title, status, message_count,
        last_message_at, metadata, created_at, updated_at
    </sql>

    <!-- 根据UUID查询 -->
    <select id="selectByConversationUuid" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM chat_conversation
        WHERE conversation_uuid = #{conversationUuid}
        LIMIT 1
    </select>

    <!-- 根据用户ID查询 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM chat_conversation
        WHERE user_id = #{userId}
        ORDER BY last_message_at DESC
    </select>

    <!-- 根据用户ID和状态查询 -->
    <select id="selectByUserIdAndStatus" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM chat_conversation
        WHERE user_id = #{userId}
        AND status = #{status}
        ORDER BY last_message_at DESC
    </select>

    <!-- 根据状态查询 -->
    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM chat_conversation
        WHERE status = #{status}
        ORDER BY last_message_at DESC
    </select>

    <!-- 统计用户的对话数量 -->
    <select id="countByUserId" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM chat_conversation
        WHERE user_id = #{userId}
    </select>

</mapper>
