<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.skill.mapper.SkillAccessControlMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.demo.skill.entity.SkillAccessControlEntity">
        <id column="id" property="id"/>
        <result column="skill_id" property="skillId"/>
        <result column="target_type" property="targetType"/>
        <result column="target_id" property="targetId"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, skill_id, target_type, target_id
    </sql>

    <!-- 根据Skill ID查询访问控制列表 -->
    <select id="selectBySkillId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM skill_access_control
        WHERE skill_id = #{skillId}
    </select>

    <!-- 根据Skill ID删除访问控制 -->
    <delete id="deleteBySkillId">
        DELETE FROM skill_access_control
        WHERE skill_id = #{skillId}
    </delete>

</mapper>
